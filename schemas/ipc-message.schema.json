{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://efl.dev/schemas/ipc-message.schema.json",
  "title": "EFL IPC Message Envelope",
  "description": "Schema for messages sent from engine DLL to TUI via named pipe (JSON Lines)",
  "type": "object",
  "required": ["type", "timestamp", "payload"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "boot.status",
        "diagnostic",
        "hook.registered",
        "hook.fired",
        "event.published",
        "save.operation",
        "mod.status",
        "phase.transition"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "payload": {
      "type": "object",
      "description": "Payload shape determined by message type"
    }
  }
}
