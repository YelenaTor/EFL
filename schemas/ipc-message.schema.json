{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://efl.dev/schemas/ipc-message.schema.json",
  "title": "EFL IPC Message Envelope",
  "description": "Schema for messages sent from engine DLL to DevKit via named pipe (JSON Lines)",
  "type": "object",
  "required": ["type", "timestamp", "payload"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "boot.status",
        "diagnostic",
        "phase.transition",
        "efl.version",
        "hook.registered",
        "hook.fired",
        "event.published",
        "save.operation",
        "mod.status",
        "area.activated",
        "npc.spawned",
        "resource.spawned",
        "resource.harvested",
        "warp.status",
        "item.granted",
        "story.fired",
        "story.native_pending",
        "story.warning",
        "quest.updated",
        "dialogue.open",
        "ipc.channel_published"
      ]
    },
    "timestamp": {
      "type": "string",
      "description": "Relative timestamp string (e.g. T+12.3s)"
    },
    "payload": {
      "type": "object",
      "description": "Payload shape determined by message type"
    }
  }
}
