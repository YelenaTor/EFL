{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://efl.dev/schemas/resource.schema.json",
  "title": "EFL Resource Definition",
  "description": "Schema for resource type definitions (harvestables, forageables, breakables)",
  "type": "object",
  "required": ["id", "kind"],
  "properties": {
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["forageable_node", "breakable_node", "harvestable_node", "special_interactable"] },
    "sprite": { "type": "string" },
    "yieldTable": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": { "type": "string" },
          "min": { "type": "integer" },
          "max": { "type": "integer" }
        }
      }
    },
    "spawnRules": {
      "type": "object",
      "properties": {
        "areas": { "type": "array", "items": { "type": "string" } },
        "anchors": {
          "type": "object",
          "description": "Per-area spawn grid position as 'grid_x,grid_y' (e.g. '3,7'). Adds the area to 'areas' automatically.",
          "additionalProperties": { "type": "string", "pattern": "^-?[0-9]+,-?[0-9]+$" }
        },
        "respawnPolicy": { "type": "string" },
        "seasonal": { "type": "array", "items": { "type": "string" } }
      }
    },
    "interaction": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "scriptMode": { "type": "string" }
      }
    }
  }
}
